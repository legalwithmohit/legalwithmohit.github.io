---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import FAQ from '@/components/FAQ.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import ContactCTA from '@/components/ContactCTA.astro';
import { formatDate, readingTime, getRelatedArticles } from '@/lib/articles';
import { SITE } from '@/site.config';

interface Props {
  entry: CollectionEntry<'articles'>;
  headings: { depth: number; slug: string; text: string }[];
}

const { entry, headings } = Astro.props;
const { title, description, category, publishDate, updatedDate, author, faqs } = entry.data;
const time = readingTime(entry.body);
const allArticles = await getCollection('articles');
const related = getRelatedArticles(entry, allArticles);

// Only include h2/h3 in the on-page table of contents to keep it scannable.
const tocHeadings = headings.filter((h) => h.depth <= 3);

const articleStructuredData = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  datePublished: publishDate.toISOString(),
  dateModified: (updatedDate ?? publishDate).toISOString(),
  articleSection: category,
  publisher: { '@type': 'Person', name: SITE.name },
});

const faqStructuredData = faqs?.length
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    })
  : null;

const structuredData = [articleStructuredData, faqStructuredData].filter(Boolean).join('\n');
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  publishDate={publishDate}
  updatedDate={updatedDate}
  structuredData={structuredData}
>
  <article class="mx-auto max-w-3xl px-6 py-14">
    <Breadcrumbs
      crumbs={[
        { label: 'Home', href: '/' },
        { label: 'Legal Insights', href: '/legal-insights/' },
        { label: title, href: `/legal-insights/${entry.slug}/` },
      ]}
    />

    <header class="mt-6 border-b border-mist pb-8">
      <span class="citation-mark">{category}</span>
      <h1 class="mt-3 font-display text-3xl font-medium leading-tight text-ink sm:text-4xl">
        {title}
      </h1>
      <p class="mt-4 text-base leading-relaxed text-slate">{description}</p>
      <p class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate">
        <span>By {author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={publishDate.toISOString()}>{formatDate(publishDate)}</time>
        <span aria-hidden="true">·</span>
        <span>{time}</span>
      </p>
    </header>

    <div class="mt-10 grid gap-10 lg:grid-cols-[1fr_220px]">
      <div class="prose prose-slate max-w-none">
        <slot />

        {faqs?.length && (
          <div class="not-prose mt-12">
            <FAQ faqs={faqs} />
          </div>
        )}
      </div>

      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block">
          <nav aria-label="Table of contents" class="sticky top-24">
            <p class="citation-mark mb-3">On this page</p>
            <ul class="space-y-2 border-l border-mist pl-4 text-sm">
              {tocHeadings.map((h) => (
                <li style={h.depth === 3 ? 'margin-left: 0.75rem' : undefined}>
                  <a href={`#${h.slug}`} class="text-slate hover:text-ink">{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}
    </div>

    {related.length > 0 && (
      <section class="mt-16 border-t border-mist pt-10" aria-labelledby="related-heading">
        <h2 id="related-heading" class="font-display text-xl font-medium text-ink">
          Related Articles
        </h2>
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((article) => <ArticleCard article={article} />)}
        </div>
      </section>
    )}

    <div class="mt-16">
      <ContactCTA />
    </div>
  </article>
</BaseLayout>

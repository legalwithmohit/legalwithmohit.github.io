---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { SITE } from '@/site.config';

const whatsappLink = `https://wa.me/${SITE.whatsapp.replace(/[^0-9]/g, '')}`;
---

<BaseLayout
  title="Contact"
  description={`Get in touch with ${SITE.name} by email, phone, or WhatsApp to book a consultation.`}
>
  <div class="mx-auto max-w-3xl px-6 py-14">
    <Breadcrumbs crumbs={[{ label: 'Home', href: '/' }, { label: 'Contact', href: '/contact/' }]} />

    <header class="mt-6">
      <p class="citation-mark">Contact</p>
      <h1 class="mt-3 font-display text-3xl font-medium text-ink sm:text-4xl">Get in touch</h1>
      <p class="mt-4 max-w-xl text-base leading-relaxed text-slate">
        The fastest way to reach me is by email or WhatsApp. Include a
        short summary of your situation and a good time to talk, and
        you'll get a reply confirming next steps.
      </p>
    </header>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      <a
        href={`mailto:${SITE.email}`}
        class="rounded-2xl border border-mist bg-white p-6 transition-colors hover:border-cobalt-100"
      >
        <p class="citation-mark">Email</p>
        <p class="mt-2 font-display text-lg text-ink">{SITE.email}</p>
      </a>

      <a
        href={`tel:${SITE.phone}`}
        class="rounded-2xl border border-mist bg-white p-6 transition-colors hover:border-cobalt-100"
      >
        <p class="citation-mark">Phone</p>
        <p class="mt-2 font-display text-lg text-ink">{SITE.phone}</p>
      </a>

      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-2xl border border-mist bg-white p-6 transition-colors hover:border-cobalt-100"
      >
        <p class="citation-mark">WhatsApp</p>
        <p class="mt-2 font-display text-lg text-ink">{SITE.whatsapp}</p>
      </a>

      <div class="rounded-2xl border border-mist bg-white p-6">
        <p class="citation-mark">Office (by appointment)</p>
        <p class="mt-2 font-display text-lg text-ink">{SITE.address}</p>
      </div>
    </div>

    <section class="mt-16" aria-labelledby="contact-form-heading">
      <h2 id="contact-form-heading" class="font-display text-xl font-medium text-ink">
        Send a message
      </h2>
      <p class="mt-2 text-sm text-slate">
        This site is fully static, so the form below is a placeholder.
        Connect it to a form backend (see <code>README.md</code>) such as
        Formspree, Netlify Forms mirrored via a proxy, or a simple
        serverless function before going live.
      </p>

      <form class="mt-6 grid gap-4" aria-describedby="form-note">
        <div>
          <label for="name" class="block text-sm font-medium text-ink">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="mt-1 w-full rounded-lg border border-mist bg-white px-4 py-2.5 text-sm text-ink focus:border-cobalt-600"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-ink">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="mt-1 w-full rounded-lg border border-mist bg-white px-4 py-2.5 text-sm text-ink focus:border-cobalt-600"
          />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-ink">
            What would you like help with?
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="mt-1 w-full rounded-lg border border-mist bg-white px-4 py-2.5 text-sm text-ink focus:border-cobalt-600"
          ></textarea>
        </div>
        <button
          type="submit"
          class="mt-2 w-fit rounded-full bg-ink px-6 py-3 text-sm font-medium text-paper transition-colors hover:bg-cobalt-700"
        >
          Send message
        </button>
        <p id="form-note" class="text-xs text-slate">
          Not connected yet — see README.md to wire this up to a form service.
        </p>
      </form>
    </section>
  </div>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="mx-auto flex max-w-xl flex-col items-center px-6 py-28 text-center">
    <p class="citation-mark">404</p>
    <h1 class="mt-3 font-display text-3xl font-medium text-ink">This page doesn't exist</h1>
    <p class="mt-4 text-base leading-relaxed text-slate">
      The page you're looking for may have moved or never existed. Try
      the homepage, or browse Legal Insights for the article you had in mind.
    </p>
    <div class="mt-8 flex gap-4">
      <a href={base} class="rounded-full bg-ink px-6 py-3 text-sm font-medium text-paper">Go home</a>
      <a href={`${base}legal-insights/`} class="rounded-full border border-ink px-6 py-3 text-sm font-medium text-ink">
        Legal Insights
      </a>
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PracticeAreaCard from '@/components/PracticeAreaCard.astro';
import ContactCTA from '@/components/ContactCTA.astro';
import { PRACTICE_AREAS } from '@/site.config';
---

<BaseLayout
  title="Practice Areas"
  description="Plain-language guides to the legal areas I practice in, organised around the situations people actually face."
>
  <div class="mx-auto max-w-6xl px-6 py-14">
    <Breadcrumbs crumbs={[{ label: 'Home', href: '/' }, { label: 'Practice Areas', href: '/practice-areas/' }]} />

    <header class="mt-6 max-w-2xl">
      <p class="citation-mark">Practice Areas</p>
      <h1 class="mt-3 font-display text-3xl font-medium text-ink sm:text-4xl">
        Find your situation, not a legal category
      </h1>
      <p class="mt-4 text-base leading-relaxed text-slate">
        Each area below covers the situations people commonly bring in,
        how the process generally works, and answers to the questions
        asked most often.
      </p>
    </header>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {PRACTICE_AREAS.map((area) => <PracticeAreaCard area={area} />)}
    </div>

    <div class="mt-16">
      <ContactCTA />
    </div>
  </div>
</BaseLayout>

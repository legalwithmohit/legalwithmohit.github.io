---
import type { PracticeArea } from '@/site.config';

interface Props {
  area: PracticeArea;
}
const { area } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}practice-areas/${area.key}/`}
  class="group block rounded-2xl border border-mist bg-white p-6 transition-all hover:border-cobalt-100 hover:shadow-[0_2px_24px_-4px_rgba(18,32,58,0.08)]"
>
  <h3 class="font-display text-xl font-medium text-ink group-hover:text-cobalt-700">
    {area.title}
  </h3>
  <p class="mt-2 text-sm leading-relaxed text-slate">{area.shortDescription}</p>
  <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-cobalt-600">
    Learn more
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">
      <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
</a>

---
interface Props {
  heading?: string;
  body?: string;
}
const {
  heading = 'Have a question about your specific situation?',
  body = 'General information can only take you so far. If you would like to discuss your circumstances directly, book a consultation.',
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="rounded-2xl bg-ink px-8 py-12 text-center sm:px-16">
  <h2 class="font-display text-2xl font-medium text-paper sm:text-3xl">{heading}</h2>
  <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-mist">{body}</p>
  <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
    <a
      href={`${base}contact/`}
      class="rounded-full bg-paper px-6 py-3 text-sm font-medium text-ink transition-colors hover:bg-mist"
    >
      Book a Consultation
    </a>
    <a
      href={`${base}legal-insights/`}
      class="rounded-full border border-slate px-6 py-3 text-sm font-medium text-paper transition-colors hover:border-paper"
    >
      Read Legal Insights
    </a>
  </div>
</section>
